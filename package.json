{
  "name": "simulation-viewer",
  "displayName": "Simulation Viewer",
  "description": "3D simulation file viewer for .vtk .vtu .vtp .mph files",
  "version": "0.0.1",
  "publisher": "NahiidIslam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nahidislam106/Simulation-Viewer.git"
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simulationViewer.openFile",
        "title": "Open in Simulation Viewer",
        "icon": "$(graph-scatter)"
      },
      {
        "command": "simulationViewer.showLog",
        "title": "Simulation Viewer: Show Log"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "simulationViewer.openFile",
          "when": "resourceExtname =~ /\\.(vtk|vtu|vtp|mph)$/",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "simulationViewer.openFile",
          "when": "resourceExtname =~ /\\.(vtk|vtu|vtp|mph)$/",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "simulationViewer.viewer",
        "displayName": "Simulation Viewer",
        "selector": [
          {
            "filenamePattern": "*.vtk"
          },
          {
            "filenamePattern": "*.vtu"
          },
          {
            "filenamePattern": "*.vtp"
          },
          {
            "filenamePattern": "*.mph"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Simulation Viewer",
      "properties": {
        "simulationViewer.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python interpreter with pyvista installed. Leave blank to auto-detect."
        },
        "simulationViewer.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start Python backend when extension activates."
        },
        "simulationViewer.keepTempFiles": {
          "type": "boolean",
          "default": false,
          "description": "Keep processed VTP files after closing (faster reopen)."
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@kitware/vtk.js": "^35.7.1",
    "@types/form-data": "^2.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.0.0",
    "form-data": "^4.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "vtk.js": "^35.7.1",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  }
}
